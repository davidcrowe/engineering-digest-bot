# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── ACP gateway (for the platform tool implementations) ───────────
# Each generated tool routes through here to run the platform-managed
# implementation (web search, memory, integrations) under governance.
# To self-host a specific tool, edit its handler body in src/index.ts.
ACP_GATEWAY_URL=https://api.makeagents.run
ACP_TENANT_SLUG=
# Generate a tenant API key in the dashboard → Settings → API Keys
ACP_TOKEN=

# Port for the Express server (default 8000).
# PORT=8000
